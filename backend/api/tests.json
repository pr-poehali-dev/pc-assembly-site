{
  "tests": [
    {
      "name": "Get posts list",
      "method": "GET",
      "path": "/?action=posts",
      "expectedStatus": 200
    },
    {
      "name": "Get reviews list",
      "method": "GET",
      "path": "/?action=reviews",
      "expectedStatus": 200
    },
    {
      "name": "Register validation fails on empty",
      "method": "POST",
      "path": "/?action=register",
      "body": {"name": "", "email": "", "password": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login wrong creds",
      "method": "POST",
      "path": "/?action=login",
      "body": {"login": "nouser_xyz", "password": "wrong"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Reset request unknown email",
      "method": "POST",
      "path": "/?action=reset-request",
      "body": {"email": "nobody_xyz@test.com"},
      "expectedStatus": 404,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}
